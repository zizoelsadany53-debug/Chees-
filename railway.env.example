# Railway environment variables for Global Chess Arena
# Copy this file to railway.env or set values in Railway project settings.

NODE_ENV=production
PORT=5000
CLIENT_URL=https://<your-app>.up.railway.app
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Use either DATABASE_URL or the separate MySQL variables.
DATABASE_URL=mysql://<user>:<password>@<host>:<port>/<database>
# MYSQLHOST=<host>
# MYSQLPORT=3306
# MYSQLUSER=<user>
# MYSQLPASSWORD=<password>
# MYSQLDATABASE=<database>

# Client environment variables for Vite production.
VITE_API_URL=https://<your-app>.up.railway.app/api
VITE_SOCKET_URL=https://<your-app>.up.railway.app
